<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.Exercise1" parent="Theme.AppCompat.Light.NoActionBar" />

    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <!-- Set the splash screen background, animated icon, and animation duration. -->
        <item name="windowSplashScreenBackground">#004C3F</item> <!-- GreenDark -->
        <!-- Use transparent icon so the native splash is purely a solid background -->
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_empty_splash</item>
        <item name="postSplashScreenTheme">@style/Theme.Exercise1</item>
    </style>
</resources>
